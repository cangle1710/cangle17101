# Copy to `.env` and fill in. These are ONLY needed when you swap in a real
# signer (see README, "Going live"). The bot runs fine in dry-run without them.

# Polygon wallet private key (hex, 0x-prefixed). Used to sign CLOB orders.
POLYGON_PRIVATE_KEY=

# Polymarket CLOB API credentials (derived from your wallet via
# py_clob_client.create_api_key).
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# Optional: alternate RPC endpoint if you implement the on-chain fallback.
POLYGON_RPC_URL=https://polygon-rpc.com
